# Server
NODE_ENV=development
PORT=3001

# Database (matches docker-compose defaults)
DATABASE_URL=postgresql://moneymind:moneymind_secret@localhost:5432/moneymind?schema=public

# Auth — use a strong random secret in production (min 32 chars)
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=7d

# CORS — set to your deployed frontend URL in production
CLIENT_URL=http://localhost:5173
